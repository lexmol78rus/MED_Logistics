# Application
NODE_ENV=development
PORT=3000

# API
API_PREFIX=api/v1

# PostgreSQL (used by Prisma)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/med_warehouse?schema=public

# JWT (generate strong secrets for production, e.g. openssl rand -base64 32)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# Logging (trace | debug | info | warn | error | fatal)
LOG_LEVEL=info

# Settings PATCH trace (raw body before ValidationPipe). Default on in development.
SETTINGS_TRACE=1
# SETTINGS_MAIL_PATCH_STUB=1

# Rate limiting (optional — wired when implementing guards)
THROTTLE_TTL=60
THROTTLE_LIMIT=100
THROTTLE_FORGOT_PASSWORD_LIMIT=5

# Password reset (Yandex SMTP)
APP_URL=http://localhost
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
