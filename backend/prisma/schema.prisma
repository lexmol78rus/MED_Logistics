generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  OPERATOR
  VIEWER
}

enum LotStatus {
  OK
  WARNING
  QUARANTINE
  BLOCKED
}

enum MovementType {
  RECEIPT
  ISSUE
  ADJUSTMENT
  QUARANTINE
  UNBLOCK
  RECALL
  BLOCK
}

model User {
  id           String    @id @default(cuid())
  email        String
  displayName  String?   @map("display_name")
  passwordHash String    @map("password_hash")
  role         UserRole  @default(OPERATOR)
  isActive     Boolean   @default(true) @map("is_active")
  deletedAt    DateTime? @map("deleted_at")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  notifications        Notification[]
  refreshTokens        RefreshToken[]
  passwordResetTokens  PasswordResetToken[]

  @@index([email])
  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Product {
  id            String   @id @default(cuid())
  sku           String   @unique
  name          String
  manufacturer  String?
  minStock      Decimal? @map("min_stock") @db.Decimal(18, 4)
  reorderPoint  Decimal? @map("reorder_point") @db.Decimal(18, 4)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  lots          Lot[]
  barcodes      BarcodeRecord[]
  inventoryRows InventoryItem[]
  movements     StockMovement[]

  @@map("products")
}

model Lot {
  id         String    @id @default(cuid())
  productId  String    @map("product_id")
  lotNumber  String    @map("lot_number")
  expiryDate DateTime? @map("expiry_date")
  mfgDate    DateTime? @map("mfg_date")
  status     LotStatus @default(OK)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  product       Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  barcodes      BarcodeRecord[]
  inventoryRows InventoryItem[]
  movements     StockMovement[]

  @@unique([productId, lotNumber])
  @@index([productId, expiryDate])
  @@map("lots")
}

model InventoryItem {
  id               String   @id @default(cuid())
  productId        String   @map("product_id")
  lotId            String   @map("lot_id")
  quantity         Decimal  @db.Decimal(18, 4)
  reservedQuantity Decimal  @default(0) @map("reserved_quantity") @db.Decimal(18, 4)
  location         String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  lot     Lot     @relation(fields: [lotId], references: [id], onDelete: Cascade)

  @@index([productId, lotId])
  @@map("inventory_items")
}

model BarcodeRecord {
  id        String   @id @default(cuid())
  barcode   String   @unique
  productId String?  @map("product_id")
  lotId     String?  @map("lot_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  lot     Lot?     @relation(fields: [lotId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([lotId])
  @@map("barcode_records")
}

model WriteOffDestination {
  id         String   @id @default(cuid())
  name       String
  type       String?
  isActive   Boolean  @default(true) @map("is_active")
  legacyCode String?  @unique @map("legacy_code")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  movements StockMovement[]

  @@map("write_off_destinations")
}

model StockMovement {
  id                    String       @id @default(cuid())
  reference             String       @unique
  productId             String       @map("product_id")
  lotId                 String?      @map("lot_id")
  type                  MovementType
  quantity              Decimal      @db.Decimal(18, 4)
  actorEmail            String?      @map("actor_email")
  writeOffDestinationId String?      @map("write_off_destination_id")
  writeOffDestination   String?      @map("write_off_destination")
  writeOffComment       String?      @map("write_off_comment")
  createdAt             DateTime     @default(now()) @map("created_at")

  product     Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  lot         Lot?                 @relation(fields: [lotId], references: [id], onDelete: SetNull)
  destination WriteOffDestination? @relation(fields: [writeOffDestinationId], references: [id], onDelete: SetNull)

  @@index([productId, createdAt])
  @@index([createdAt])
  @@index([writeOffDestinationId])
  @@map("stock_movements")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?  @map("actor_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

model Notification {
  id        String               @id @default(cuid())
  userId    String?              @map("user_id")
  type      String
  priority  NotificationPriority @default(NORMAL)
  title     String
  message   String
  channel   String               @default("in_app")
  payload   Json?
  href      String?
  readAt    DateTime?            @map("read_at")
  createdAt DateTime             @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([type, createdAt])
  @@map("notifications")
}

model SystemSetting {
  id        String   @id @default("default")
  payload   Json
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by")

  @@map("system_settings")
}
