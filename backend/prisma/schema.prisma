generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  OPERATOR
  VIEWER
}

enum LotStatus {
  OK
  WARNING
  QUARANTINE
  BLOCKED
}

enum MovementType {
  RECEIPT
  ISSUE
  ADJUSTMENT
  QUARANTINE
  UNBLOCK
  RECALL
  BLOCK
}

enum ExpectedReceiptStatus {
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum ExpectedReceiptEventType {
  CREATED
  RECEIVED
  UPDATED
  CANCELLED
  CLOSED
}

enum CounterpartyType {
  CUSTOMER
  SUPPLIER
}

enum ContractDocType {
  DOCX
  HTML
  PDF
  OTHER
}

enum ShipmentPickingOutcome {
  SUCCESS
  PARTIAL
  ISSUE
}

enum ShipmentStatus {
  NEW
  PICKING
  PICKING_ON_HOLD
  PICKED
  DISPATCHED
}

model User {
  id           String    @id @default(cuid())
  email        String
  displayName  String?   @map("display_name")
  passwordHash String    @map("password_hash")
  role         UserRole  @default(OPERATOR)
  isActive     Boolean   @default(true) @map("is_active")
  deletedAt    DateTime? @map("deleted_at")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  notifications        Notification[]
  refreshTokens        RefreshToken[]
  passwordResetTokens  PasswordResetToken[]

  @@index([email])
  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Product {
  id            String   @id @default(cuid())
  sku           String   @unique
  name          String
  manufacturer  String?
  minStock      Decimal? @map("min_stock") @db.Decimal(18, 4)
  reorderPoint  Decimal? @map("reorder_point") @db.Decimal(18, 4)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  lots             Lot[]
  barcodes         BarcodeRecord[]
  inventoryRows    InventoryItem[]
  movements        StockMovement[]
  expectedReceipts           ExpectedReceipt[]
  registrationCertificates   ProductRegistrationCertificate[]
  shipmentItems              ShipmentItem[]

  @@map("products")
}

model ProductRegistrationCertificate {
  id           String   @id @default(cuid())
  productId    String   @map("product_id")
  fileName     String   @map("file_name")
  originalName String   @map("original_name")
  mimeType     String   @map("mime_type")
  fileSize     Int      @map("file_size")
  storagePath  String   @map("storage_path")
  uploadedBy   String?  @map("uploaded_by")
  createdAt    DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt])
  @@map("product_registration_certificates")
}

model Lot {
  id         String    @id @default(cuid())
  productId  String    @map("product_id")
  lotNumber  String    @map("lot_number")
  expiryDate DateTime? @map("expiry_date")
  mfgDate    DateTime? @map("mfg_date")
  status     LotStatus @default(OK)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  product       Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  barcodes      BarcodeRecord[]
  inventoryRows InventoryItem[]
  movements     StockMovement[]

  @@unique([productId, lotNumber])
  @@index([productId, expiryDate])
  @@map("lots")
}

model InventoryItem {
  id               String   @id @default(cuid())
  productId        String   @map("product_id")
  lotId            String   @map("lot_id")
  quantity         Decimal  @db.Decimal(18, 4)
  reservedQuantity Decimal  @default(0) @map("reserved_quantity") @db.Decimal(18, 4)
  location         String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  lot     Lot     @relation(fields: [lotId], references: [id], onDelete: Cascade)

  @@index([productId, lotId])
  @@map("inventory_items")
}

model BarcodeRecord {
  id        String   @id @default(cuid())
  barcode   String   @unique
  productId String?  @map("product_id")
  lotId     String?  @map("lot_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  lot     Lot?     @relation(fields: [lotId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([lotId])
  @@map("barcode_records")
}

model WriteOffDestination {
  id         String   @id @default(cuid())
  name       String
  type       String?
  isActive   Boolean  @default(true) @map("is_active")
  legacyCode String?  @unique @map("legacy_code")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  movements StockMovement[]

  @@map("write_off_destinations")
}

model StockMovement {
  id                    String       @id @default(cuid())
  reference             String       @unique
  productId             String       @map("product_id")
  lotId                 String?      @map("lot_id")
  type                  MovementType
  quantity              Decimal      @db.Decimal(18, 4)
  actorEmail            String?      @map("actor_email")
  writeOffDestinationId String?      @map("write_off_destination_id")
  writeOffDestination   String?      @map("write_off_destination")
  writeOffComment       String?      @map("write_off_comment")
  operationGroupId      String?      @map("operation_group_id")
  correctedMovementId   String?      @map("corrected_movement_id")
  correctionSessionId   String?      @map("correction_session_id")
  editReason            String?      @map("edit_reason")
  shipmentId            String?      @map("shipment_id")
  createdAt             DateTime     @default(now()) @map("created_at")

  product           Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  shipment          Shipment?            @relation(fields: [shipmentId], references: [id], onDelete: SetNull)
  lot               Lot?                 @relation(fields: [lotId], references: [id], onDelete: SetNull)
  destination       WriteOffDestination? @relation(fields: [writeOffDestinationId], references: [id], onDelete: SetNull)
  correctedMovement StockMovement?       @relation("MovementCorrections", fields: [correctedMovementId], references: [id], onDelete: SetNull)
  corrections       StockMovement[]      @relation("MovementCorrections")

  @@index([productId, createdAt])
  @@index([createdAt])
  @@index([writeOffDestinationId])
  @@index([operationGroupId])
  @@index([correctedMovementId])
  @@index([correctionSessionId])
  @@index([shipmentId])
  @@map("stock_movements")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?  @map("actor_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

model Notification {
  id        String               @id @default(cuid())
  userId    String?              @map("user_id")
  type      String
  priority  NotificationPriority @default(NORMAL)
  title     String
  message   String
  channel   String               @default("in_app")
  payload   Json?
  href      String?
  readAt    DateTime?            @map("read_at")
  createdAt DateTime             @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([type, createdAt])
  @@map("notifications")
}

model SystemSetting {
  id        String   @id @default("default")
  payload   Json
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by")

  @@map("system_settings")
}

model ExpectedReceipt {
  id          String                @id @default(cuid())
  productId   String                @map("product_id")
  orderedQty  Decimal               @map("ordered_qty") @db.Decimal(18, 4)
  receivedQty Decimal               @default(0) @map("received_qty") @db.Decimal(18, 4)
  status      ExpectedReceiptStatus @default(ORDERED)
  comment     String?
  createdBy   String?               @map("created_by")
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")

  product Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  events  ExpectedReceiptEvent[]

  @@index([productId, status])
  @@index([status])
  @@map("expected_receipts")
}

model ExpectedReceiptEvent {
  id                String                   @id @default(cuid())
  expectedReceiptId String                   @map("expected_receipt_id")
  type              ExpectedReceiptEventType
  quantity          Decimal?                 @db.Decimal(18, 4)
  message           String?
  actorEmail        String?                  @map("actor_email")
  createdAt         DateTime                 @default(now()) @map("created_at")

  expectedReceipt ExpectedReceipt @relation(fields: [expectedReceiptId], references: [id], onDelete: Cascade)

  @@index([expectedReceiptId, createdAt])
  @@map("expected_receipt_events")
}

model Counterparty {
  id        String           @id @default(cuid())
  type      CounterpartyType
  name      String
  fullName  String?          @map("full_name")
  inn       String?
  kpp       String?
  comment   String?
  isActive  Boolean          @default(true) @map("is_active")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  contracts Contract[]
  shipments Shipment[]

  @@index([type, isActive])
  @@index([name])
  @@map("counterparties")
}

model Contract {
  id             String          @id @default(cuid())
  counterpartyId String          @map("counterparty_id")
  number         String          @map("number")
  date           DateTime?       @map("date")
  title          String?
  docType        ContractDocType @default(OTHER) @map("doc_type")
  originalName   String          @map("original_name")
  mimeType       String          @map("mime_type")
  fileSize       Int             @map("file_size")
  fileName       String          @map("file_name")
  storagePath    String          @map("storage_path")
  uploadedBy     String?         @map("uploaded_by")
  procurementItems Json?         @map("procurement_items")
  procurementParsedAt DateTime?  @map("procurement_parsed_at")
  procurementParseError String?  @map("procurement_parse_error")
  createdAt      DateTime        @default(now()) @map("created_at")

  counterparty Counterparty @relation(fields: [counterpartyId], references: [id], onDelete: Cascade)
  shipments    Shipment[]

  @@unique([counterpartyId, number])
  @@index([number])
  @@index([counterpartyId, createdAt])
  @@map("contracts")
}

model Shipment {
  id             String         @id @default(cuid())
  status         ShipmentStatus @default(NEW)
  counterpartyId String?        @map("counterparty_id")
  contractId     String?        @map("contract_id")
  note           String?
  createdBy      String?        @map("created_by")
  pickingSentAt      DateTime? @map("picking_sent_at")
  pickingPausedAt    DateTime? @map("picking_paused_at")
  pickingRecalledAt        DateTime?               @map("picking_recalled_at")
  warehouseMessage         String?                 @map("warehouse_message")
  pickingOutcome           ShipmentPickingOutcome? @map("picking_outcome")
  pickingCompleteComment   String?                 @map("picking_complete_comment")
  pickedAt                 DateTime?               @map("picked_at")
  writeoffCompletedAt      DateTime?               @map("writeoff_completed_at")
  createdAt                DateTime                @default(now()) @map("created_at")
  updatedAt                DateTime                @updatedAt @map("updated_at")

  counterparty Counterparty? @relation(fields: [counterpartyId], references: [id], onDelete: SetNull)
  contract     Contract?     @relation(fields: [contractId], references: [id], onDelete: SetNull)
  items        ShipmentItem[]
  movements    StockMovement[]

  @@index([status, createdAt])
  @@index([counterpartyId])
  @@index([contractId])
  @@map("shipments")
}

model ShipmentItem {
  id             String   @id @default(cuid())
  shipmentId     String   @map("shipment_id")
  productId      String?  @map("product_id")
  name           String
  code           String?
  unit           String?
  vatRate        String?  @map("vat_rate")
  priceWithVat   Decimal? @map("price_with_vat") @db.Decimal(18, 4)
  quantity       Decimal  @db.Decimal(18, 4)
  sum            Decimal? @db.Decimal(18, 4)
  contractLineNo Int?     @map("contract_line_no")
  managerNote    String?  @map("manager_note")
  managerTag     String?  @map("manager_tag")

  shipment Shipment  @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  product  Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([shipmentId])
  @@index([productId])
  @@map("shipment_items")
}
