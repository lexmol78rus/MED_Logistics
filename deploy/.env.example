# Medical Warehouse Management System — production deployment environment
# Copy to deploy/.env and adjust before running docker compose.

# PostgreSQL (use deploy/scripts/generate-prod-env.sh for strong secrets)
POSTGRES_USER=med_warehouse
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=med_warehouse

# Backend API
NODE_ENV=production
API_PREFIX=api/v1
LOG_LEVEL=info
JWT_ACCESS_SECRET=change-me-access-secret-min-32-characters-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-characters-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
THROTTLE_TTL=60
THROTTLE_LIMIT=100
THROTTLE_FORGOT_PASSWORD_LIMIT=5
# Temporary integration debugging (request/response + Prisma queries)
INTEGRATION_DEBUG=false

# Settings PATCH tracing (RAW body before ValidationPipe). Default on when NODE_ENV!=production.
SETTINGS_TRACE=1
# Set to 1 to stub PATCH /settings/mail (isolates mail vs warehouse save errors)
# SETTINGS_MAIL_PATCH_STUB=1

# Password reset emails (Yandex SMTP — do not commit real credentials)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# Encrypts SMTP passwords stored in system_settings (openssl rand -hex 32)
SETTINGS_ENCRYPTION_KEY=

# Frontend (Vite build-time — same-origin nginx: use /api/v1)
VITE_API_URL=/api/v1
VITE_APP_ENV=production
GEMINI_API_KEY=
APP_URL=http://192.168.11.8

# Published ports (host mapping)
HTTP_PORT=80
API_PORT=3000
POSTGRES_PORT=5432
