# Medical Warehouse Management System — production deployment environment
# Copy to deploy/.env and adjust before running docker compose.

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=med_warehouse

# Backend API
NODE_ENV=production
API_PREFIX=api/v1
LOG_LEVEL=info
JWT_ACCESS_SECRET=change-me-access-secret-min-32-characters-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-characters-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Frontend (build-time / runtime metadata)
GEMINI_API_KEY=
APP_URL=http://localhost

# Published ports (host mapping)
HTTP_PORT=80
API_PORT=3000
POSTGRES_PORT=5432
